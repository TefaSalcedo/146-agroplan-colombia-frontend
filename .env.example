# Local backend. For production, use the public HTTPS API URL.
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# Public site origin used for canonical URLs, Open Graph, sitemap, and robots metadata.
# NEXT_PUBLIC_SITE_URL=https://agroplan.tefasalcedo.com

# Trusted origin used by the server-side PDF renderer.
# Set this to the deployed HTTPS origin in Vercel.
PDF_ORIGIN=http://localhost:3000
